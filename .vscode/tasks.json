{
    "tasks": [{
        "type": "cppbuild",
        "label": "Compile sstrings",
        "detail": "Compile the sstrings project",
        "command": "gcc.exe",
        "args": [
            "-fdiagnostics-color=always",
            "-g",
            "-Wall",
            "-Wextra",
            "-Werror=conversion",
            "-I${workspaceFolder}/src",
            "${workspaceFolder}/src/sstrings.c",
            "${workspaceFolder}/main.c",
            "-o",
            "${workspaceFolder}/main.exe"
        ],
        "problemMatcher": [
            "$gcc"
        ],
        "group": {
            "kind": "build",
            "isDefault": false
        }
    }, {
        "type": "cppbuild",
        "label": "Compile current test",
        "detail": "Compile the current sstrings test",
        "command": "gcc.exe",
        "args": [
            "-fdiagnostics-color=always",
            "-g",
            "-Wall",
            "-Wextra",
            "-Werror=conversion",
            "-I${workspaceFolder}/src",
            "${workspaceFolder}/src/sstrings.c",
            "${workspaceFolder}/tests/${fileBasenameNoExtension}/${fileBasename}",
            "-o",
            "${workspaceFolder}/tests/${fileBasenameNoExtension}/${fileBasenameNoExtension}.exe"
        ],
        "problemMatcher": [
            "$gcc"
        ],
        "group": {
            "kind": "build",
            "isDefault": false
        }
    }],
    "version": "2.0.0"
}